{
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "http://app.alpha.openscaler.net:9077/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "http://app.alpha.openscaler.net:9077/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "http://app.alpha.openscaler.net:9077/media/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
