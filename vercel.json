{
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "https://app.alpha.openscaler.net/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://app.alpha.openscaler.net/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://app.alpha.openscaler.net/media/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
