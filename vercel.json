{
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "https://ercp-algerie.com/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://ercp-algerie.com/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://ercp-algerie.com/media/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
